{
  "name": "fair-do-designer",
  "version": "0.10.0-preview",
  "license": "Apache-2.0",
  "scripts": {
    "prebuild": "bunx --bun tsc -p tsconfig.js-boilerplate.json; bash include-jsonaccess-libs-public.sh",
    "predev": "bunx --bun tsc -p tsconfig.js-boilerplate.json; bash include-jsonaccess-libs-public.sh",
    "dev": "npm-run-all -p dev-boilerplate dev-webworker dev-next",
    "build": "npm-run-all -p build-webworker build-next",
    "dev-next": "bun --bun next dev --turbopack",
    "build-next": "bun --bun next build --turbopack",
    "start": "bunx --bun serve@latest out",
    "lint": "bun --bun eslint .",
    "postbuild": "pagefind --site out --glob docs/**/*.{html} --output-path out/_pagefind",
    "dev-webworker": "webpack --config webpack.config.webworker.js --mode=development --watch",
    "build-webworker": "webpack --config webpack.config.webworker.js --mode=production",
    "dev-boilerplate": "bunx --bun tsc --watch -p tsconfig.js-boilerplate.json",
    "clean": "rm -rf dist out .next .turbo node_modules public/js/*"
  },
  "dependencies": {
    "@blockly/block-plus-minus": "^9.0.9",
    "@blockly/field-dependent-dropdown": "^5.0.9",
    "@kit-data-manager/pid-component": "^0.3.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@types/memoizee": "^0.4.12",
    "blockly": "^12.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fflate": "^0.8.2",
    "jsonpath-plus": "^10.3.0",
    "jsonpointerx": "^1.2.5",
    "lucide-react": "^0.563.0",
    "memoizee": "^0.4.17",
    "next": "^16.0.7",
    "next-themes": "^0.4.6",
    "nextra": "^4.6.1",
    "nextra-theme-docs": "^4.6.1",
    "quickjs-emscripten": "^0.31.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-resizable-panels": "^4",
    "tailwind-merge": "^3.5.0",
    "swr": "^2.4.0",
    "usehooks-ts": "^3.1.1",
    "webpack": "^5.105.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/bun": "^1.3.10",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "eslint-plugin-react-hooks": "^7.0.1",
    "npm-run-all": "^4.1.5",
    "pagefind": "^1.4.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "ts-loader": "^9.5.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "webpack-cli": "^7.0.2"
  },
  "description": "A client-side web application to generate code for generating PID Records for FAIR DOs.",
  "keywords": [
    "fair",
    "do",
    "fairdo",
    "fair-do",
    "designer",
